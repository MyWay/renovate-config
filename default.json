{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "postUpdateOptions": ["pnpmDedupe"],
  "requireConfig": "required",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": true,
    "automergeType": "pr",
    "vulnerabilityFixStrategy": "lowest",
    "minimumReleaseAge": "0 days"
  },
  "packageRules": [
    {
      "description": "Automerge regular patch updates after CI passes",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Keep regular minor updates reviewable",
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "description": "Automerge minor-version security patches",
      "matchUpdateTypes": ["minor"],
      "matchIsVulnerabilityAlert": true,
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "1 days"
    }
    {
      "description": "Gate major updates through dashboard approval",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    }
  ]
}